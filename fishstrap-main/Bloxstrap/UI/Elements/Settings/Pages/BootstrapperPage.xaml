<ui:UiPage x:Class="Bloxstrap.UI.Elements.Settings.Pages.BehaviourPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:Bloxstrap.UI.Elements.Settings.Pages"
      xmlns:controls="clr-namespace:Bloxstrap.UI.Elements.Controls"
      xmlns:models="clr-namespace:Bloxstrap.UI.ViewModels.Settings"
      xmlns:resources="clr-namespace:Bloxstrap.Resources"
      d:DataContext="{d:DesignInstance Type=models:BehaviourViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="2000" d:DesignWidth="800"
      Title="BehaviourPage"
      Scrollable="True">

    <StackPanel Margin="0,0,14,14">
        <TextBlock Margin="0,0,0,8" Text="{x:Static resources:Strings.Menu_Behaviour_Description}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <controls:OptionControl 
            Header="{x:Static resources:Strings.Menu_Behaviour_ConfirmLaunches_Title}"
            Description="{x:Static resources:Strings.Menu_Behaviour_ConfirmLaunches_Description}">
            <ui:ToggleSwitch IsChecked="{Binding ConfirmLaunches, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl 
            Header="{x:Static resources:Strings.Menu_Behaviour_ForceRobloxLanguage_Title}"
            Description="{x:Static resources:Strings.Menu_Behaviour_ForceRobloxLanguage_Description}"
            HelpLink="https://github.com/bloxstraplabs/bloxstrap/wiki/Information-on-Roblox-app-localisation">
            <ui:ToggleSwitch IsChecked="{Binding ForceRobloxLanguage, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl 
            Header="{x:Static resources:Strings.Menu_Behaviour_BackgroundUpdates_Title}"
            Description="{x:Static resources:Strings.Menu_Behaviour_BackgroundUpdates_Description}">
            <ui:ToggleSwitch IsChecked="{Binding BackgroundUpdates, Mode=TwoWay}" />
        </controls:OptionControl>

        <ui:CardExpander Grid.Row="1" Margin="0,8,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="14" Text="{x:Static resources:Strings.Menu_Bootstrapper_CleanUp_Title}" />
                        <TextBlock Margin="0,2,0,0" FontSize="12" Text="{x:Static resources:Strings.Menu_Bootstrapper_CleanUp_Description}" Foreground="{DynamicResource TextFillColorTertiaryBrush}"  />
                    </StackPanel>
                </Grid>
            </ui:CardExpander.Header>

            <StackPanel>
                <controls:OptionControl 
    Header="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Age_Title}" 
    Description="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Age_Description}">
                    <ComboBox Width="200" Padding="10,5,10,5" ItemsSource="{Binding CleanerOptions, Mode=OneTime}" Text="{Binding CleanerOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </controls:OptionControl>
                <controls:OptionControl 
    Header="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Cache_Title}" 
    Description="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Cache_Description}">
                    <ui:ToggleSwitch IsChecked="{Binding CleanerCache, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl
    Header="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_StudioCache_Title}"
    Description="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_StudioCache_Description}">
                    <ui:ToggleSwitch IsChecked="{Binding CleanerStudioCache, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl 
    Header="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Logs_Title}" 
    Description="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_Logs_Description}">
                    <ui:ToggleSwitch IsChecked="{Binding CleanerLogs, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl 
    Header="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_IncludeBloxstrap_Title}"
    Description="{x:Static resources:Strings.Menu_Bootstrapper_Cleaner_IncludeBloxstrap_Description}">
                    <ui:ToggleSwitch IsChecked="{Binding CleanerVanStrap, Mode=TwoWay}" />
                </controls:OptionControl>
            </StackPanel>
        </ui:CardExpander>
        <TextBlock Text="Experimental" FontSize="20" FontWeight="Medium" Margin="0,16,0,0" />
        <controls:MarkdownTextBlock MarkdownText="A collection of experimental settings. Be careful while using them, as they may or may not work as intended." TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        <controls:OptionControl 
            Header="{x:Static resources:Strings.Menu_Bootstrapper_AllowCookieAccess_Title}"
            Description="{Binding Source={x:Static resources:Strings.Menu_Bootstrapper_AllowCookieAccess_Description}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://github.com/jovanpogi1231-a11y/VananaStrap/wiki'}">
            
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning20" Margin="0,2,8,0" Foreground="Orange">
                    <ui:SymbolIcon.Style>
                        <Style TargetType="ui:SymbolIcon" BasedOn="{StaticResource {x:Type ui:SymbolIcon}}">
                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.CookieLoadingFailed, RelativeSource={RelativeSource AncestorType=ui:UiPage}}" Value="True">
                                    <Setter Property="ui:SymbolIcon.Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:SymbolIcon.Style>
                </ui:SymbolIcon>
                <ui:ToggleSwitch IsChecked="{Binding CookieAccess, Mode=TwoWay}" />
            </StackPanel>
        </controls:OptionControl>

        <controls:OptionControl 
            Header="{x:Static resources:Strings.Bootstrapper_Experimental_BetterMatchmaking_Title}"
            Description="{x:Static resources:Strings.Bootstrapper_Experimental_BetterMatchmaking_Description}">
            <StackPanel Orientation="Horizontal">
                <ui:ToggleSwitch IsChecked="{Binding EnableBetterMatchmaking, Mode=TwoWay}" />
            </StackPanel>
        </controls:OptionControl>

        <controls:OptionControl 
            Header="{x:Static resources:Strings.Bootstrapper_Experimental_BetterMatchmaking_RandomizeServer_Title}"
            Description="{x:Static resources:Strings.Bootstrapper_Experimental_BetterMatchmaking_RandomizeServer_Description}">
            <StackPanel Orientation="Horizontal">
                <ui:ToggleSwitch IsChecked="{Binding EnableBetterMatchmakingRandomization, Mode=TwoWay}" />
            </StackPanel>
        </controls:OptionControl>

        <controls:OptionControl 
            Header="Enable Borderless Fullscreen for Vulkan"
            Description="Let's you use a fake version of borderless fullscreen while using Vulkan."
            IsEnabled="{Binding VulkanFullscreenAllowed, Mode=OneWay}">
            <StackPanel Orientation="Horizontal">
                <ui:ToggleSwitch IsChecked="{Binding EnableFakeBorderlessFullscreen, Mode=TwoWay}" />
            </StackPanel>
        </controls:OptionControl>
		<controls:OptionControl
	Header="{x:Static resources:Strings.Menu_Behaviour_MultiInstance_Title}"
	Description="{x:Static resources:Strings.Menu_Behaviour_MultiInstance_Description}">
			<ui:ToggleSwitch IsChecked="{Binding MultiInstanceLaunching, Mode=TwoWay}" />
		</controls:OptionControl>
		<ui:Card Margin="0,8,0,0">
			<ui:Card.Style>
				<Style TargetType="ui:Card" BasedOn="{StaticResource {x:Type ui:Card}}">
					<Setter Property="Visibility" Value="Collapsed" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding CookieAccess}" Value="True">
							<Setter Property="Visibility" Value="Visible" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</ui:Card.Style>

			<StackPanel>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" VerticalAlignment="Center">
						<TextBlock FontSize="14" Text="{x:Static resources:Strings.Menu_Behaviour_AccountManager_Title}" />
						<TextBlock Margin="0,2,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{x:Static resources:Strings.Menu_Behaviour_AccountManager_Description}" />
					</StackPanel>
					<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
						<ui:Button Icon="ArrowClockwise16" Content="{x:Static resources:Strings.Menu_Behaviour_AccountManager_Refresh}" Command="{Binding RefreshInstancesCommand}" Margin="0,0,8,0" />
						<ui:Button Icon="PersonAdd24" Appearance="Primary" Content="{x:Static resources:Strings.Menu_Behaviour_AccountManager_AddAccount}" Command="{Binding AddAccountCommand}" />
					</StackPanel>
				</Grid>

				<TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{x:Static resources:Strings.Menu_Behaviour_AccountManager_NoInstances}">
					<TextBlock.Style>
						<Style TargetType="TextBlock">
							<Setter Property="Visibility" Value="Visible" />
							<Style.Triggers>
								<DataTrigger Binding="{Binding HasRunningInstances}" Value="True">
									<Setter Property="Visibility" Value="Collapsed" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</TextBlock.Style>
				</TextBlock>

				<ItemsControl Margin="0,8,0,0" ItemsSource="{Binding RobloxInstances}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Margin="0,4,0,0" Padding="10" CornerRadius="4" Background="{DynamicResource ControlFillColorDefaultBrush}">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto" />
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>

									<Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{DynamicResource ControlFillColorSecondaryBrush}" VerticalAlignment="Center">
										<Grid>
											<ui:SymbolIcon Symbol="Person24" HorizontalAlignment="Center" VerticalAlignment="Center" />
											<Ellipse Width="40" Height="40">
												<Ellipse.Fill>
													<ImageBrush ImageSource="{Binding Avatar}" Stretch="UniformToFill" />
												</Ellipse.Fill>
											</Ellipse>
										</Grid>
									</Border>

									<StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
										<TextBlock FontSize="14">
											<TextBlock.Style>
												<Style TargetType="TextBlock">
													<Setter Property="Text" Value="{x:Static resources:Strings.Menu_Behaviour_AccountManager_SignedOut}" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding HasAccount}" Value="True">
															<Setter Property="Text" Value="{Binding Username}" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</TextBlock.Style>
										</TextBlock>
										<TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{Binding ProcessId, StringFormat='PID: {0}'}" />
									</StackPanel>

									<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
										<ui:Button Icon="ArrowEnter24" Content="{x:Static resources:Strings.Menu_Behaviour_AccountManager_Login}" Command="{Binding LoginCommand}" Margin="0,0,8,0">
											<ui:Button.Style>
												<Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
													<Setter Property="Visibility" Value="Visible" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding HasAccount}" Value="True">
															<Setter Property="Visibility" Value="Collapsed" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</ui:Button.Style>
										</ui:Button>
										<ui:Button Icon="ArrowExit20" Content="{x:Static resources:Strings.Menu_Behaviour_AccountManager_Logout}" Command="{Binding LogoutCommand}" Margin="0,0,8,0">
											<ui:Button.Style>
												<Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
													<Setter Property="Visibility" Value="Collapsed" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding HasAccount}" Value="True">
															<Setter Property="Visibility" Value="Visible" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</ui:Button.Style>
										</ui:Button>
										<ui:Button Icon="Delete24" Content="{x:Static resources:Strings.Menu_Behaviour_AccountManager_Remove}" Command="{Binding RemoveCommand}" />
									</StackPanel>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</ui:Card>
    </StackPanel>
</ui:UiPage>
