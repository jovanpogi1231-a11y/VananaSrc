<ui:UiPage x:Class="Bloxstrap.UI.Elements.Settings.Pages.BehaviourPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:models="clr-namespace:Bloxstrap.UI.ViewModels"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:resources="clr-namespace:Bloxstrap.Resources"
      xmlns:controls="clr-namespace:Bloxstrap.UI.Elements.Controls"
      xmlns:dmodels="clr-namespace:Bloxstrap.UI.ViewModels.Settings"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance dmodels:BehaviourViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="800" d:DesignWidth="800"
      Title="BehaviourPage"
      Scrollable="True">
    <StackPanel Margin="0,0,14,14">

        <controls:OptionControl
            Header="Multi-instance launching"
            Description="Allow more than one Roblox instance to run at the same time.">
            <ui:ToggleSwitch IsChecked="{Binding MultiInstanceLaunching, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Allow cookie access"
            Description="Required for the account manager. VanStrap will read and write the Roblox authentication cookie on this device.">
            <ui:ToggleSwitch IsChecked="{Binding CookieAccess, Mode=TwoWay}" />
        </controls:OptionControl>

        <ui:InfoBar
            Margin="0,8,0,0"
            IsClosable="False"
            IsOpen="{Binding CookieLoadingFailed, Mode=OneWay}"
            Severity="Warning"
            Title="Cookie"
            Message="The Roblox cookie could not be loaded. The account manager may not work correctly." />

        <TextBlock Text="Account manager" FontSize="20" FontWeight="Medium" Margin="0,16,0,0" />
        <TextBlock
            Margin="0,2,0,0"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
            TextWrapping="Wrap"
            Text="Manage Roblox accounts and assign them to running Roblox instances. Enable 'Allow cookie access' to use this feature." />

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" IsEnabled="{Binding CookieAccess, Mode=OneWay}">
            <ui:Button
                Icon="PersonAdd24"
                Content="Log in with Roblox"
                Appearance="Primary"
                Command="{Binding AddAccountCommand}" />
            <ui:Button
                Margin="8,0,0,0"
                Icon="ArrowClockwise24"
                Content="Refresh"
                Command="{Binding RefreshInstancesCommand}" />
        </StackPanel>

        <ui:InfoBar
            Margin="0,12,0,0"
            IsClosable="False"
            IsOpen="True"
            Severity="Informational"
            Title="No running instances"
            Message="No running Roblox instances were found. Launch Roblox to manage its account here.">
            <ui:InfoBar.Style>
                <Style TargetType="ui:InfoBar">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasRunningInstances}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CookieAccess}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ui:InfoBar.Style>
        </ui:InfoBar>

        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding RobloxInstances}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:Card Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Width="48" Height="48"
                                CornerRadius="24"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <Border.Clip>
                                    <EllipseGeometry Center="24,24" RadiusX="24" RadiusY="24" />
                                </Border.Clip>
                                <Image Source="{Binding Avatar}" Stretch="UniformToFill" />
                            </Border>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="14" FontWeight="Medium">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding DisplayName}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasAccount}" Value="False">
                                                    <Setter Property="Text" Value="No account assigned" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="{Binding Username}" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                    Text="{Binding ProcessId, StringFormat='PID: {0}'}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:Button
                                    Icon="PersonAvailable24"
                                    Content="Log in"
                                    Command="{Binding LoginCommand}" />
                                <ui:Button
                                    Margin="8,0,0,0"
                                    Icon="PersonProhibited24"
                                    Content="Log out"
                                    Command="{Binding LogoutCommand}"
                                    IsEnabled="{Binding HasAccount}" />
                                <ui:Button
                                    Margin="8,0,0,0"
                                    Icon="Delete24"
                                    Appearance="Danger"
                                    Command="{Binding RemoveCommand}"
                                    IsEnabled="{Binding HasAccount}" />
                            </StackPanel>
                        </Grid>
                    </ui:Card>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</ui:UiPage>